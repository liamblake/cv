\ProvidesPackage{style_resume}[14/03/20202]

\RequirePackage[dvipsnames,table]{xcolor}
\RequirePackage{fontspec}
\RequirePackage{academicons}

% Style
% \setmainfont{Segoe UI}
\renewcommand{\familydefault}{\sfdefault}

% Color definitions
\definecolor{IFHeading}{HTML}{393939}
\definecolor{IFAccent}{HTML}{00a002}
\definecolor{IFBody}{HTML}{1c1c1c}
\definecolor{IFEmphasis}{HTML}{4D4D4F}


\colorlet{heading}{IFHeading}
\colorlet{accent}{IFAccent}
\colorlet{emphasis}{IFEmphasis}
\colorlet{body}{IFBody}

% Change the bullets for itemize and rating marker
% for \cvskill if you want to
\renewcommand{\itemmarker}{{\small\textbullet}}
\renewcommand{\ratingmarker}{\faCircle}

\hyphenpenalty=10000
\exhyphenpenalty=10000



% Header and section
\newcommand{\cvsection}[2][]{%
\vspace{5mm}%
\ifstrequal{#1}{}{}{\marginpar{\vspace*{\dimexpr1pt-\baselineskip}\raggedright\input{#1}}}%
{\color{heading}\LARGE\bfseries{#2}}\\[-1.5ex]%
{\color{heading}\rule{\linewidth}{1.1pt}\par}\smallskip
}

\newcommand{\cvsubsection}[1]{%
	\bigskip%
	{\color{emphasis}\large\bfseries{#1}\par}
}



% Event
\newcommand{\cvevent}[3]{%
	{\large\color{emphasis}\textbf{#1}\par}
	\smallskip
	\large\textbf{\color{accent}#2}\par
	\smallskip
	\small\makebox[0.5\linewidth][l]{\faCalendar\hspace{0.5em}#3}%
	\smallskip\normalsize
}

% Achievement
\newcommand{\cvachievement}[3]{%
	\begin{tabularx}{\linewidth}{@{}p{2em} @{\hspace{1ex}} >{\raggedright\arraybackslash}X@{}}
		\multirow{2}{*}{\Large\color{accent}#1} & \bfseries\textcolor{emphasis}{\small #2} \\
		                                        & #3
	\end{tabularx}%
	\smallskip
}

% Skill box - inspired by PP resume example
\newcommand{\skill}[1]{\large\textcolor{emphasis}{#1} |}

%\colorbox{accent}{\large\textcolor{white}{\textbf{\strut #1}}}\hspace{0.5em}\vspace{0.1em}}


% Side divider
\newcommand{\divider}{\vspace{2mm}\textcolor{body!30}{\hdashrule{\linewidth}{0.6pt}{0.5ex}}\vspace{2.5mm}}


% Remove default header and footer lines
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
